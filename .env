APP_ENV=development
APP_PORT=8080
GRPC_PORT=9090
WS_PORT=8081

JWT_SECRET=your-256-bit-secret-key-here-must-be-at-least-32-characters
JWT_EXPIRE_HOURS=24

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# MySQL — 留空则使用内存存储
MYSQL_DSN=root:stu123@tcp(127.0.0.1:3305)/gin_high_performance?charset=utf8mb4&collation=utf8mb4_unicode_ci&parseTime=True&loc=Local

# OpenTelemetry — 设为 stdout 或留空则输出到控制台
OTEL_ENDPOINT=localhost:4318
OTEL_INSECURE=true

LOG_LEVEL=info

WS_READ_LIMIT=512

# Cloudflare Tunnel
CLOUDFLARED_PATH=D:\cloudflared.exe
