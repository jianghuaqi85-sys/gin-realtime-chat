# ===== 应用配置 =====
APP_ENV=development
APP_PORT=8080
GRPC_PORT=9090
WS_PORT=8081

# ===== JWT（必填，至少 32 字符） =====
JWT_SECRET=your-256-bit-secret-key-here-must-be-at-least-32-characters
JWT_EXPIRE_HOURS=24

# ===== Redis =====
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== MySQL（留空则使用内存存储，聊天功能不可用） =====
MYSQL_DSN=

# ===== OpenTelemetry =====
OTEL_ENDPOINT=
OTEL_INSECURE=true

# ===== 日志 =====
LOG_LEVEL=info
DB_LOG_LEVEL=warn

# ===== WebSocket =====
WS_ALLOWED_ORIGIN=
WS_READ_LIMIT=4096

# ===== Cloudflare Tunnel（留空则不自动启动） =====
CLOUDFLARED_PATH=
